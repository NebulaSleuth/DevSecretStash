@page
@model DevSecretStash.Api.Pages.LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <h1>DevSecretStash</h1>
    <p class="subtitle">Sign in to manage your secret collections</p>

    <div class="card">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-error">@Model.ErrorMessage</div>
        }

        <form method="post">
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="Email" value="@Model.Email" required autofocus />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="Password" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width: 100%;">Sign In</button>
        </form>
    </div>
</div>
