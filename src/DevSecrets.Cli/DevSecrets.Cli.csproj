<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>devsecrets</ToolCommandName>
    <PackageOutputPath>./nupkg</PackageOutputPath>
    <PackageId>DevSecrets</PackageId>
    <Version>0.1.0</Version>
    <Authors>DevSecrets Contributors</Authors>
    <Description>Securely sync .NET user-secrets across machines with end-to-end encryption</Description>
    <PackageTags>dotnet-tool;user-secrets;sync;encryption;security</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\DevSecrets.Core\DevSecrets.Core.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>
</Project>
